# Manuelles Befüllen — alternativ einfach `./init.sh` ausführen, dann wird .env automatisch erzeugt.

# Domain dieser Instanz (öffentlich, DNS muss zeigen, Traefik holt Zertifikat)
DOMAIN=cloud.example.com

# Externe MariaDB
# WICHTIG: PRIVATE Cloud-Network-IP — nicht die öffentliche!
DB_HOST=10.0.0.X
DB_NAME=db_example
DB_USER=user_example
DB_PASSWORD=<NEUES_PASSWORT>

# Nextcloud-Admin (wird beim ersten Start automatisch angelegt)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=<ADMIN_PASSWORT>
