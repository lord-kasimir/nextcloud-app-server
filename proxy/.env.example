# E-Mail für Let's-Encrypt-Account (Ablauf-Warnungen)
ACME_EMAIL=admin@example.com

# Domain für das Traefik-Dashboard
TRAEFIK_DOMAIN=traefik.example.com

# Basic-Auth-User für das Dashboard im Format user:bcrypt-hash
# Hash erzeugen: docker run --rm httpd:alpine htpasswd -nbB admin "GeheimesPasswort"
# In .env $-Zeichen verdoppeln: $$ statt $
DASHBOARD_AUTH=admin:$$2y$$05$$BEISPIEL_BCRYPT_HASH_HIER_EINSETZEN
