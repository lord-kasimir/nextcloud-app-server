# Beispiel-Konfiguration — Kopie als .env speichern und Werte ausfüllen.

# Domain der Nextcloud-Instanz (öffentlich erreichbar via Cloudflare/DNS)
DOMAIN=cloud.example.com

# Datenbank — externe MariaDB auf dem DB-Server
# Wichtig: PRIVATE Cloud-Network-IP verwenden (nicht die öffentliche!)
DB_HOST=10.0.0.X
DB_NAME=db_nc
DB_USER=db_nc_usr
DB_PASSWORD=<NEUES_PASSWORT>

# E-Mail-Adresse für Let's Encrypt (Ablauf-Warnungen)
LE_EMAIL=admin@example.com
