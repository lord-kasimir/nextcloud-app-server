# Konfiguration für tools/abschluss-check.sh.
# Kopiere diese Datei zu `abschluss-check.env` und trage die echten Werte ein.

# === Server-IPs ===
APP_SERVER_IPv4_PUBLIC=46.224.36.170     # öffentliche IP des App-Servers (für SSH)
APP_SERVER_IPv4_PRIVATE=10.0.0.2         # private Cloud-Network-IP des App-Servers
DB_SERVER_PRIVATE_IP=10.0.0.3            # private IP des DB-Servers
FILE_SERVER_IPv4_PRIVATE=10.0.0.4        # private IP des File-Servers

# === Domains ===
NEUE_SUBDOMAIN=t1.smartmusikschule.de    # die NC-Pilot-Domain
TRAEFIK_DOMAIN=traefik.hittie.de         # Traefik-Dashboard-Domain

# === NC-Instanz ===
INSTANCE_NAME=pilot                      # Name der Instanz (= Verzeichnis unter instances/)
DB_NAME=db_pilot                         # MariaDB-Datenbank-Name (aus init.sh)

# === SSH ===
SSH_KEY=$HOME/.ssh/id_cloudrms           # Pfad zum Private-Key

# Repo-Pfad auf App-Server (Standard: /opt/nextcloud-app-server)
APP_REPO_PATH=/opt/nextcloud-app-server
